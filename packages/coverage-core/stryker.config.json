{
  "$schema": "https://unpkg.com/@stryker-mutator/core/schema/stryker-schema.json",
  "_comment": "Mutation testing for coverage-core. Targets the parser/sanitizer surface where line+branch coverage is 100% — surviving mutants reveal weak assertions.",
  "packageManager": "pnpm",
  "plugins": ["@stryker-mutator/vitest-runner"],
  "testRunner": "vitest",
  "ignorePatterns": ["dist", "coverage", ".stryker-tmp"],
  "tempDirName": ".stryker-tmp",
  "vitest": {
    "configFile": "vitest.stryker.config.ts"
  },
  "vitest_comment": "configFile defaults to vitest.config.ts in the project root.",
  "mutate": [
    "src/customization.ts",
    "src/diagnostics.ts",
    "src/history.ts",
    "src/languages.ts",
    "src/lcov.ts",
    "src/math.ts",
    "src/report.ts"
  ],
  "incremental": true,
  "incrementalFile": ".stryker-tmp/incremental.json",
  "thresholds": {
    "high": 90,
    "low": 75,
    "break": 60
  },
  "reporters": ["html", "clear-text", "progress"],
  "htmlReporter": {
    "fileName": "../../reports/stryker/coverage-core.html"
  },
  "concurrency": 4
}
