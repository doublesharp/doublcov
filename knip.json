{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "workspaces": {
    ".": {
      "entry": ["scripts/*.mjs"],
      "project": ["scripts/**/*.{ts,mjs}", "*.{ts,mjs}"]
    },
    "packages/coverage-core": {
      "entry": ["test/**/*.test.ts"],
      "project": ["src/**/*.ts", "test/**/*.ts"]
    },
    "packages/cli": {
      "entry": ["test/**/*.test.ts"],
      "project": ["src/**/*.ts", "test/**/*.ts"]
    },
    "apps/web": {
      "entry": ["test/**/*.test.ts"],
      "project": ["src/**/*.{ts,vue}", "test/**/*.ts"]
    }
  },
  "ignoreExportsUsedInFile": true,
  "ignoreDependencies": [
    "tailwindcss",
    "madge",
    "esbuild",
    "postject",
    "publint"
  ]
}
