{
  "name": "doublcov-workspace",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "build": "pnpm -r --sort run build && pnpm --filter @0xdoublesharp/doublcov run bundle:web",
    "binary": "node scripts/build-binary.mjs",
    "build:binary": "pnpm run build && pnpm run binary",
    "clean": "pnpm -r --parallel run clean",
    "smoke:package": "node scripts/smoke-npm-package.mjs",
    "check:package": "node scripts/check-package-contents.mjs",
    "coverage:lcov": "node scripts/coverage-lcov.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:circular": "node scripts/check-circular.mjs",
    "lint:knip": "knip",
    "lint:package": "pnpm --filter @0xdoublesharp/doublcov exec publint --strict",
    "mutate:core": "pnpm --filter @0xdoublesharp/doublcov-core exec stryker run",
    "test": "pnpm -r --workspace-concurrency=1 --if-present run test",
    "test:fuzz": "pnpm -r --if-present run test:fuzz",
    "test:e2e": "pnpm run build && playwright test",
    "typecheck": "pnpm -r --if-present run typecheck",
    "typecheck:scripts": "tsc -p tsconfig.scripts.json",
    "verify:publish": "pnpm run build && pnpm run typecheck && pnpm run typecheck:scripts && pnpm run lint && pnpm run lint:circular && pnpm run lint:knip && pnpm run test && pnpm run lint:package && pnpm run check:package && pnpm run smoke:package",
    "dev": "pnpm --filter @0xdoublesharp/doublcov-web run dev"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/typescript-checker": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@types/node": "latest",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.2.1",
    "eslint-plugin-vue": "^10.9.0",
    "fast-check": "^4.7.0",
    "globals": "^17.5.0",
    "knip": "^6.7.0",
    "madge": "^8.0.0",
    "postject": "1.0.0-alpha.6",
    "prettier": "^3.8.3",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.59.0",
    "vitest": "latest",
    "vue-eslint-parser": "^10.4.0"
  }
}
